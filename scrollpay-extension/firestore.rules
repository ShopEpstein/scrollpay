rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read/write their own doc only
    match /sp_users/{userId} {
      allow read, write: if true;
    }

    // Impressions: anyone can create, only owner can read
    match /sp_impressions/{impId} {
      allow read, write: if true;
    }

    // Ads: public read, no client writes
    match /sp_ads/{adId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
