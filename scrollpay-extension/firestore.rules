rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Largest single legitimate award (referral bonus = 50 sats).
    function maxAward() { return 50; }

    // Balances may only grow — never be rewritten to an arbitrary value.
    function balancesOnlyGrow() {
      return request.resource.data.totalSats >= resource.data.totalSats
        && request.resource.data.totalImpressions >= resource.data.totalImpressions;
    }

    // A single write may add at most one action's worth of sats / impression.
    // No daily cap — users earn unlimited XP for every ad viewed.
    function awardWithinLimits() {
      return (request.resource.data.totalSats - resource.data.totalSats) <= maxAward()
        && (request.resource.data.totalImpressions - resource.data.totalImpressions) <= 1;
    }

    // Users: balance-bearing docs.
    match /sp_users/{userId} {
      allow read: if true;

      // New accounts must start empty — no pre-loaded balance.
      allow create: if request.resource.data.totalSats == 0
        && request.resource.data.satsToday == 0
        && request.resource.data.totalImpressions == 0
        && request.resource.data.impressionsToday == 0;

      // Updates may add a single capped award, or leave balances untouched
      // (e.g. saving a Lightning address).
      allow update: if balancesOnlyGrow() && awardWithinLimits();

      allow delete: if false;
    }

    // Impressions: append-only log; the recorded award is bounded.
    match /sp_impressions/{impId} {
      allow read: if true;
      allow create, update: if request.resource.data.satsAwarded <= maxAward();
      allow delete: if false;
    }

    // Ads: public read.
    // Authenticated advertisers may create and manage their own ads.
    // Counter fields (impressions, clicks, budgetUsed) are immutable from the
    // client — only server-side functions should update them.
    match /sp_ads/{adId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.impressions == 0
        && request.resource.data.clicks == 0
        && request.resource.data.budgetUsed == 0;

      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.impressions == resource.data.impressions
        && request.resource.data.clicks == resource.data.clicks
        && request.resource.data.budgetUsed == resource.data.budgetUsed;

      allow delete: if false;
    }

    // Waitlist: anyone can submit their email once; no reads or deletes.
    match /sp_waitlist/{entryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3;
      allow read, update, delete: if false;
    }

    // Global counters (signup number, etc.). Only the userCount field grows.
    match /sp_meta/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['userCount'])
        && request.resource.data.userCount is int
        && request.resource.data.userCount >= 1;
      allow update: if request.resource.data.userCount > resource.data.userCount;
    }

    // XP/SCROLL exchange — order book: public read; anyone can post (rate-limited by API).
    match /sp_scroll_orders/{orderId} {
      allow read: if true;
      allow write: if false; // all writes go through the API
    }

    // XP/SCROLL exchange — trade history: public read only.
    match /sp_scroll_trades/{tradeId} {
      allow read: if true;
      allow write: if false; // admin only via API
    }
  }
}
