{
  "redirects": [
    { "source": "/r/:code", "destination": "/?ref=:code", "permanent": false }
  ],
  "rewrites": [
    { "source": "/privacy",          "destination": "/docs/privacy.html" },
    { "source": "/market",           "destination": "/docs/market.html" },
    { "source": "/economics",        "destination": "/docs/economics.html" },
    { "source": "/xp-scroll",        "destination": "/docs/xp-scroll.html" },
    { "source": "/api/scroll-market","destination": "/api/scroll-market.js" },
    { "source": "/api/sweep-xp",     "destination": "/api/sweep-xp.js" },
    { "source": "/api/admin-sweep",   "destination": "/api/admin-sweep.js" },
    { "source": "/advertiser",      "destination": "/advertiser/index.html" },
    { "source": "/advertiser/(.*)", "destination": "/advertiser/$1" },
    { "source": "/partners",        "destination": "/docs/partners/index.html" },
    { "source": "/partners/:slug",  "destination": "/docs/partners/partner.html" },
    { "source": "/api/partners",    "destination": "/api/partners.js" },
    { "source": "/api/admin-partners", "destination": "/api/admin-partners.js" },
    { "source": "/api/admin-users",    "destination": "/api/admin-users.js" },
    { "source": "/api/wallets",         "destination": "/api/wallets.js" },
    { "source": "/api/record-click",   "destination": "/api/record-click.js" },
    { "source": "/api/faucet",          "destination": "/api/faucet.js" },
    { "source": "/api/raffle-entry",   "destination": "/api/raffle-entry.js" },
    { "source": "/",                "destination": "/docs/index.html" },
    { "source": "/(.*)",            "destination": "/docs/$1" }
  ]
}
